# Anthropic API Key (for Claude model)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# X (Twitter) OAuth 2.0 credentials
# Get these from https://developer.x.com/en/portal/projects-and-apps
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# Optional bypass secret for non-browser evaluators / smoke tests.
# When set, requests carrying `x-eval-secret: <value>` skip Twitter auth.
EVAL_SECRET=

# Arize Phoenix Cloud (or self-hosted Phoenix)
# Get these from https://app.phoenix.arize.com
# For self-hosted Phoenix on the default port, use http://localhost:6006/v1/traces
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space-name/v1/traces
PHOENIX_API_KEY=your-phoenix-api-key
PHOENIX_PROJECT_NAME=wonder-toys-beeai-ts
