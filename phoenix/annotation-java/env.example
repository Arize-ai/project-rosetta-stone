# Anthropic API Key (for Claude model, used by the Java backend via the official anthropic-java SDK)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# X (Twitter) OAuth 2.0 credentials
# Get these from https://developer.x.com/en/portal/projects-and-apps
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# Backend communication (shared secret between Next.js and the Java backend)
BACKEND_SECRET=generate-a-shared-secret-here
BACKEND_URL=http://localhost:18004

# ChromaDB (used by the Java backend at runtime, and by the sibling indexer at dev startup)
CHROMA_URL=http://localhost:8000

# Arize Phoenix Cloud (or self-hosted Phoenix)
# Get these from https://app.phoenix.arize.com
# For self-hosted Phoenix at default port, use http://localhost:6006/v1/traces (no api-key needed)
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space-name/v1/traces
PHOENIX_API_KEY=your-phoenix-api-key
PHOENIX_PROJECT_NAME=wonder-toys-annotation-java
