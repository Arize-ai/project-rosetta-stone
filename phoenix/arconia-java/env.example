# Anthropic API Key (for Claude model, used by the Arconia Java backend)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# X (Twitter) OAuth 2.0 credentials
# Get these from https://developer.x.com/en/portal/projects-and-apps
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# Backend communication (shared secret between Next.js and the Java backend)
BACKEND_SECRET=generate-a-shared-secret-here
BACKEND_URL=http://localhost:18005

# ChromaDB (used by the Java backend at runtime, and by the sibling indexer at dev startup)
CHROMA_URL=http://localhost:8000

# Arize Phoenix Cloud (or self-hosted Phoenix).
# IMPORTANT: this tier uses Arconia's OTel auto-config, which auto-appends `/v1/traces` to the
# endpoint. So PHOENIX_COLLECTOR_ENDPOINT here is the *base* URL — do NOT include `/v1/traces`.
# This differs from the other tiers (mastra/langchain-py/langchain4j-java/spring-ai-java) where
# the endpoint includes `/v1/traces`. Self-hosted Phoenix: use `http://localhost:6006` (no auth).
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space-name
PHOENIX_API_KEY=your-phoenix-api-key
PHOENIX_PROJECT_NAME=wonder-toys-arconia-java
