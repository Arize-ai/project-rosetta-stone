# Vercel AI Gateway key (for the Eve agent's Claude model)
# Eve routes `anthropic/claude-sonnet-4.6` through the AI Gateway.
AI_GATEWAY_API_KEY=your-ai-gateway-key-here

# Eve agent dev server (the Next.js chat route proxies to this)
EVE_PORT=2000
EVE_URL=http://127.0.0.1:2000

# Optional: eval-bypass header secret for headless smoke tests against /api/chat
# EVAL_SECRET=some-shared-secret

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# X (Twitter) OAuth 2.0 credentials
# Get these from https://developer.x.com/en/portal/projects-and-apps
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# Arize Phoenix Cloud
# Get these from https://app.phoenix.arize.com
# The Eve agent (eve-agent/) reads these in agent/instrumentation.ts.
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space-name/v1/traces
PHOENIX_API_KEY=your-phoenix-api-key
PHOENIX_PROJECT_NAME=wonder-toys-eve
