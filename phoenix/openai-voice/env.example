# OpenAI API key — used by the Python backend for both Realtime voice and
# Chat Completions text fallback.
OPENAI_API_KEY=sk-your-openai-key-here

# Optional model overrides
# OPENAI_REALTIME_MODEL=gpt-realtime
# OPENAI_REALTIME_VOICE=alloy
# OPENAI_TEXT_MODEL=gpt-4o

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# X (Twitter) OAuth 2.0 credentials
# Get these from https://developer.x.com/en/portal/projects-and-apps
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# Backend communication (shared secret between Next.js and Python backend)
BACKEND_SECRET=generate-a-shared-secret-here
BACKEND_URL=http://localhost:8001
NEXT_PUBLIC_VOICE_WS_URL=ws://localhost:8001/voice

# ChromaDB (used by Python backend)
CHROMA_URL=http://localhost:8000

# Arize Phoenix Cloud — https://app.phoenix.arize.com
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space-name
PHOENIX_API_KEY=your-phoenix-api-key
PHOENIX_PROJECT_NAME=wonder-toys-openai-voice

# Evals (optional — for synthetic-request runs that need to bypass NextAuth)
# EVAL_SECRET=any-random-string
# EVAL_BASE_URL=http://localhost:3000
