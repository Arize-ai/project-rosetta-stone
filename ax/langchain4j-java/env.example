# Anthropic API Key (for Claude model, used by the LangChain4j Java backend)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# X (Twitter) OAuth 2.0 credentials
# Get these from https://developer.x.com/en/portal/projects-and-apps
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# Backend communication (shared secret between Next.js and the Java backend)
BACKEND_SECRET=generate-a-shared-secret-here
BACKEND_URL=http://localhost:8001

# ChromaDB (used by the Java backend at runtime, and by the sibling indexer at dev startup)
CHROMA_URL=http://localhost:8000

# Arize AX
# Get these from https://app.arize.com
ARIZE_SPACE_ID=your-arize-space-id
ARIZE_API_KEY=your-arize-api-key
ARIZE_PROJECT_NAME=wonder-toys-langchain4j-java
